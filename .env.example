# Copy to .env and fill in. Do not commit .env.

MYSQL_HOST=localhost
MYSQL_USER=relicbot
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=relicbot

# API keys: comma-separated. Clients send via Authorization: Bearer <key> or X-API-Key.
# read_only: GET only. read_write: GET + POST/PUT/DELETE.
API_KEYS_READ_ONLY=
API_KEYS_READ_WRITE=

# Optional: create first user with npm run create-user (uses CREATE_USER_NAME / CREATE_USER_PASSWORD if set)
# CREATE_USER_NAME=admin
# CREATE_USER_PASSWORD=secret
